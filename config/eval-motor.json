{
  "checkIntervalMs": 300000,
  "passCount": 5,
  "targetMetric": 1,
  "maxMutations": 50,
  "mutationCooldownMs": 10000,
  "commandTimeoutMs": 120000,
  "rollbackOnRegression": true,
  "minImprovementEpsilon": 0.001,
  "measurement": {
    "command": "python",
    "args": [
      "-m", "pytest", "backend/tests/", "-q", "--tb=no", "-x"
    ],
    "cwd": "."
  },
  "evaluator": {
    "command": "node",
    "args": [
      "-e",
      "const s=require('fs').readFileSync('/dev/stdin','utf8');const pass=!s.includes('FAILED')&&!s.includes('error');console.log(JSON.stringify({pass:pass?1:0,evidence:s.slice(-200)}))"
    ]
  },
  "mutator": {
    "command": "node",
    "args": [
      "-e",
      "const ctx=require('fs').readFileSync('/dev/stdin','utf8');const t=require('fs').readFileSync(process.argv[1],'utf8');console.log(JSON.stringify({hypothesis:'auto-refine based on test failures',content:t,mode:'replace'}))",
      "skills/target_skill.md"
    ]
  },
  "targetFilePath": "skills/target_skill.md",
  "logLevel": "info"
}
